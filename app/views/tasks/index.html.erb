<main class="min-h-screen bg-slate-100 py-10">
  <div class="mx-auto w-full max-w-4xl px-4">
    <h1 class="text-3xl font-bold text-slate-900">Simple TODO App</h1>
    <p class="mt-1 text-sm text-slate-600">Create and manage your tasks.</p>

    <% if notice.present? %>
      <div class="mt-4 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">
        <%= notice %>
      </div>
    <% end %>

    <section class="mt-6 rounded-lg bg-white p-6 shadow">
      <h2 class="text-lg font-semibold text-slate-900">Add Task</h2>
      <%= form_with model: @task, url: tasks_path, class: "mt-4 space-y-4" do |f| %>
        <div>
          <%= f.label :title, class: "block text-sm font-medium text-slate-700" %>
          <%= f.text_field :title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
          <% @task.errors.full_messages_for(:title).each do |message| %>
            <p class="mt-1 text-sm text-red-600"><%= message %></p>
          <% end %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium text-slate-700" %>
          <%= f.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
        </div>

        <div>
          <%= f.submit "Create Task", class: "inline-flex items-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        </div>
      <% end %>
    </section>

    <section class="mt-6 rounded-lg bg-white p-6 shadow">
      <h2 class="text-lg font-semibold text-slate-900">Tasks</h2>
      <% if @tasks.empty? %>
        <p class="mt-4 text-sm text-slate-600">No tasks yet.</p>
      <% else %>
        <ul class="mt-4 space-y-3">
          <% @tasks.each do |task| %>
            <li class="flex items-start justify-between gap-4 rounded-md border border-slate-200 p-4">
              <div>
                <%= link_to task.title, task_path(task), class: "text-base font-semibold text-blue-700 hover:underline" %>
                <% if task.description.present? %>
                  <p class="mt-1 text-sm text-slate-600"><%= truncate(task.description, length: 80) %></p>
                <% end %>
              </div>
              <%= button_to "Delete", task_path(task), method: :delete, class: "rounded-md bg-red-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-red-700", data: { turbo_confirm: "Delete this task?" } %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </section>
  </div>
</main>
