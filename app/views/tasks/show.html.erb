<main class="min-h-screen bg-slate-100 py-10">
  <div class="mx-auto w-full max-w-3xl px-4">
    <% if notice.present? %>
      <div class="mb-4 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-800">
        <%= notice %>
      </div>
    <% end %>

    <article class="rounded-lg bg-white p-6 shadow">
      <h1 class="text-2xl font-bold text-slate-900"><%= @task.title %></h1>
      <div class="mt-4 whitespace-pre-wrap text-slate-700">
        <%= @task.description.presence || "No description provided." %>
      </div>

      <div class="mt-6 flex items-center gap-3">
        <%= link_to "Back to tasks", tasks_path, class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        <%= button_to "Delete task", task_path(@task), method: :delete, class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-700", data: { turbo_confirm: "Delete this task?" } %>
      </div>
    </article>
  </div>
</main>
