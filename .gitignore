# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.example

# Ignore all default key files.
/config/master.key

# Ignore all logfiles and tempfiles.
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite files).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/db/*.sqlite3
/db/*.sqlite3-*

# Ignore assets.
/public/assets

# Ignore CI service artifacts.
/coverage/

# Ignore all environment files from credentials.
/config/credentials/*.key

# Ignore node modules and package manager files if JS tooling is added later.
/node_modules
npm-debug.log
yarn-error.log

# Ignore local editor and OS files.
.DS_Store
.idea
.vscode
